{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.clarvia.org/schemas/v0.1/document_requirement.schema.json",
  "title": "DocumentRequirement",
  "description": "A document or certificate required to complete a bereavement task. Describes what is needed, who issues it, and where to obtain it.",
  "type": "object",
  "required": ["id", "name", "jurisdiction", "language", "sourceRefs", "reviewStatus"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^doc-[a-z]{2}-[a-z0-9-]+$",
      "description": "Unique document requirement identifier. Format: doc-{country}-{slug}."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the required document, e.g. 'Acte de décès'."
    },
    "nameTranslations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "description": {
      "type": "string",
      "description": "What this document is and why it is needed."
    },
    "descriptionTranslations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "jurisdiction": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "issuerId": {
      "type": "string",
      "pattern": "^inst-[a-z]{2}-[a-z0-9-]+$",
      "description": "Institution that issues this document."
    },
    "obtainedFrom": {
      "type": "string",
      "pattern": "^inst-[a-z]{2}-[a-z0-9-]+$",
      "description": "Institution where the bereaved person requests this document (may differ from issuer)."
    },
    "format": {
      "type": "string",
      "enum": ["original", "certified-copy", "simple-copy", "digital", "apostille"],
      "description": "Required format of the document."
    },
    "copiesRequired": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of copies typically needed."
    },
    "fee": {
      "type": "object",
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "notes": { "type": "string" }
      },
      "description": "Cost to obtain this document, if applicable."
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" },
      "description": "Conditions under which this document is required."
    },
    "notes": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "institution.schema.json#/$defs/sourceRef" }
    },
    "reviewStatus": {
      "$ref": "source.schema.json#/$defs/verificationStatus"
    },
    "reviewEvents": {
      "type": "array",
      "items": { "$ref": "review_event.schema.json" }
    }
  }
}
