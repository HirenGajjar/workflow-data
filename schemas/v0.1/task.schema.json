{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.clarvia.org/schemas/v0.1/task.schema.json",
  "title": "Task",
  "description": "A discrete action the bereaved person (or their representative) must perform as part of a bereavement workflow.",
  "type": "object",
  "required": ["id", "title", "jurisdiction", "language", "sourceRefs", "reviewStatus"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task-[a-z]{2}-[a-z0-9-]+$",
      "description": "Unique task identifier. Format: task-{country}-{slug}."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "titleTranslations": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Translated titles. Keys are ISO 639-1 codes."
    },
    "description": {
      "type": "string",
      "description": "Plain-language explanation of what the task involves."
    },
    "descriptionTranslations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "jurisdiction": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "Primary language of this task's content."
    },
    "institutionId": {
      "type": "string",
      "pattern": "^inst-[a-z]{2}-[a-z0-9-]+$",
      "description": "Institution responsible for or involved in this task."
    },
    "documentRequirements": {
      "type": "array",
      "items": { "type": "string", "pattern": "^doc-[a-z]{2}-[a-z0-9-]+$" },
      "description": "IDs of DocumentRequirement objects needed for this task."
    },
    "deadlines": {
      "type": "array",
      "items": { "type": "string", "pattern": "^dl-[a-z]{2}-[a-z0-9-]+$" },
      "description": "IDs of Deadline objects that apply to this task."
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" },
      "description": "IDs of Condition objects that gate this task."
    },
    "category": {
      "type": "string",
      "enum": [
        "civil-status",
        "financial",
        "insurance",
        "pension",
        "property",
        "tax",
        "healthcare",
        "employment",
        "utilities",
        "digital",
        "funeral",
        "legal",
        "other"
      ],
      "description": "Broad category for grouping and filtering."
    },
    "urgency": {
      "type": "string",
      "enum": ["immediate", "short-term", "medium-term", "long-term", "ongoing"],
      "description": "Relative urgency classification."
    },
    "notes": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "institution.schema.json#/$defs/sourceRef" }
    },
    "reviewStatus": {
      "$ref": "source.schema.json#/$defs/verificationStatus"
    },
    "reviewEvents": {
      "type": "array",
      "items": { "$ref": "review_event.schema.json" }
    }
  }
}
