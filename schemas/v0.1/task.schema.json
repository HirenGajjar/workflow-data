{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.org/schemas/v0.1/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "object_type",
    "title",
    "jurisdiction",
    "phase",
    "action_verb",
    "source_ids",
    "verification_status",
    "publication_status",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
    },
    "object_type": {
      "const": "Task"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": ["string", "null"]
    },
    "jurisdiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country"],
      "properties": {
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "region": {
          "type": ["string", "null"]
        },
        "municipality": {
          "type": ["string", "null"]
        }
      }
    },
    "phase": {
      "type": "string",
      "enum": [
        "immediate",
        "registration",
        "funeral",
        "estate",
        "tax",
        "benefits",
        "cross_border",
        "other"
      ]
    },
    "action_verb": {
      "type": "string"
    },
    "target_institution_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^institution:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "required_document_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^document:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "deadline_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^deadline:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "condition_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^condition:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "prerequisite_task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^task:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^source:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "discovered",
        "structured-from-source",
        "source-checked",
        "expert-reviewed",
        "published",
        "stale-review",
        "superseded"
      ]
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "published",
        "withheld",
        "archived"
      ]
    },
    "review_event_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^review:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "created_by": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "updated_by": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
