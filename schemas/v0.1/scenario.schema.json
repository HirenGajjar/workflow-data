{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.clarvia.org/schemas/v0.1/scenario.schema.json",
  "title": "Scenario",
  "description": "A specific bereavement situation defined by a set of Condition values. Scenarios select which Workflows and conditional Tasks apply to the user.",
  "type": "object",
  "required": ["id", "title", "conditionValues", "workflowIds"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^scn-[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "titleTranslations": { "type": "object", "additionalProperties": { "type": "string" } },
    "description": { "type": "string" },
    "descriptionTranslations": { "type": "object", "additionalProperties": { "type": "string" } },
    "conditionValues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["conditionId", "value"],
        "additionalProperties": false,
        "properties": {
          "conditionId": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" },
          "value": { "description": "The assumed value for this condition in this scenario." }
        }
      }
    },
    "workflowIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^wf-[a-z]{2}-[a-z0-9-]+$" },
      "description": "Workflows activated by this scenario."
    },
    "notes": { "type": "string" }
  }
}
