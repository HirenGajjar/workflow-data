{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.org/schemas/v0.1/scenario.schema.json",
  "title": "Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "object_type",
    "title",
    "scenario_type",
    "countries",
    "condition_ids",
    "source_ids",
    "verification_status",
    "publication_status",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^scenario:[a-z0-9-]+(:[a-z0-9-]+)*$"
    },
    "object_type": {
      "const": "Scenario"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": ["string", "null"]
    },
    "scenario_type": {
      "type": "string",
      "enum": [
        "single_jurisdiction",
        "cross_border",
        "corridor",
        "prototype",
        "other"
      ]
    },
    "countries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{2}$"
      },
      "uniqueItems": true
    },
    "condition_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^condition:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "workflow_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^workflow:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^source:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "discovered",
        "structured-from-source",
        "source-checked",
        "expert-reviewed",
        "published",
        "stale-review",
        "superseded"
      ]
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "published",
        "withheld",
        "archived"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "created_by": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "updated_by": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
