{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.clarvia.org/schemas/v0.1/workflow.schema.json",
  "title": "Workflow",
  "description": "An ordered sequence of Tasks forming a bereavement workflow for a specific jurisdiction.",
  "type": "object",
  "required": ["id", "title", "jurisdiction", "language", "tasks", "sourceRefs", "reviewStatus"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^wf-[a-z]{2}-[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "titleTranslations": { "type": "object", "additionalProperties": { "type": "string" } },
    "description": { "type": "string" },
    "descriptionTranslations": { "type": "object", "additionalProperties": { "type": "string" } },
    "jurisdiction": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "language": { "type": "string", "pattern": "^[a-z]{2}$" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["taskId"],
        "additionalProperties": false,
        "properties": {
          "taskId": { "type": "string", "pattern": "^task-[a-z]{2}-[a-z0-9-]+$" },
          "order": { "type": "integer", "minimum": 1 },
          "phase": { "type": "string", "enum": ["immediate","first-week","first-month","first-quarter","first-year","ongoing"] },
          "optional": { "type": "boolean", "default": false },
          "conditions": { "type": "array", "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" } }
        }
      }
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" },
      "description": "Conditions that apply to the entire workflow."
    },
    "notes": { "type": "string" },
    "sourceRefs": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "institution.schema.json#/$defs/sourceRef" }
    },
    "reviewStatus": { "$ref": "source.schema.json#/$defs/verificationStatus" },
    "reviewEvents": { "type": "array", "items": { "$ref": "review_event.schema.json" } }
  }
}
