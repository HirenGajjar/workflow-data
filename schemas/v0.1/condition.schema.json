{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.org/schemas/v0.1/condition.schema.json",
  "title": "Condition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "object_type",
    "label",
    "condition_type",
    "jurisdiction",
    "source_ids",
    "verification_status",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^condition:[a-z0-9-]+(:[a-z0-9-]+)*$"
    },
    "object_type": {
      "const": "Condition"
    },
    "label": {
      "type": "string"
    },
    "condition_type": {
      "type": "string",
      "enum": [
        "death_location",
        "habitual_residence",
        "nationality",
        "heir_location",
        "asset_location",
        "marital_status",
        "presence_of_will",
        "property_ownership",
        "cross_border",
        "other"
      ]
    },
    "jurisdiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country"],
      "properties": {
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "region": {
          "type": ["string", "null"]
        },
        "municipality": {
          "type": ["string", "null"]
        }
      }
    },
    "expression": {
      "type": "object",
      "description": "Simple structured condition expression.",
      "additionalProperties": true
    },
    "human_readable": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^source:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "discovered",
        "structured-from-source",
        "source-checked",
        "expert-reviewed",
        "published",
        "stale-review",
        "superseded"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "created_by": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "updated_by": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
