{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.org/schemas/v0.1/deadline.schema.json",
  "title": "Deadline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "object_type",
    "label",
    "jurisdiction",
    "trigger",
    "source_ids",
    "verification_status",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^deadline:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
    },
    "object_type": {
      "const": "Deadline"
    },
    "label": {
      "type": "string"
    },
    "jurisdiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["country"],
      "properties": {
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "region": {
          "type": ["string", "null"]
        },
        "municipality": {
          "type": ["string", "null"]
        }
      }
    },
    "trigger": {
      "type": "string",
      "enum": [
        "date_of_death",
        "date_death_discovered",
        "date_certificate_issued",
        "date_notification_received",
        "date_burial",
        "other"
      ]
    },
    "duration": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": ["hours", "days", "weeks", "months", "years"]
        }
      }
    },
    "text": {
      "type": "string",
      "description": "Human-readable deadline statement from or based on the official source."
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^source:[a-z]{2}:[a-z0-9-]+(:[a-z0-9-]+)*$"
      },
      "uniqueItems": true
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "discovered",
        "structured-from-source",
        "source-checked",
        "expert-reviewed",
        "published",
        "stale-review",
        "superseded"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "created_by": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "updated_by": {
          "type": ["string", "null"]
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
