{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.clarvia.org/schemas/v0.1/deadline.schema.json",
  "title": "Deadline",
  "description": "A time constraint on a bereavement task. Deadlines are relative to a triggering event (typically date of death) and may be legal or advisory.",
  "type": "object",
  "required": ["id", "description", "jurisdiction", "language", "relativeTo", "sourceRefs", "reviewStatus"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^dl-[a-z]{2}-[a-z0-9-]+$",
      "description": "Unique deadline identifier. Format: dl-{country}-{slug}."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable description of the deadline."
    },
    "descriptionTranslations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "jurisdiction": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$"
    },
    "type": {
      "type": "string",
      "enum": ["legal", "regulatory", "contractual", "recommended", "practical"],
      "description": "Whether the deadline is legally binding or advisory."
    },
    "relativeTo": {
      "type": "string",
      "enum": ["date-of-death", "date-of-burial", "date-of-notification", "task-completion", "custom"],
      "description": "The event from which the deadline is measured."
    },
    "relativeToCustom": {
      "type": "string",
      "description": "Description of the custom reference event, when relativeTo is 'custom'."
    },
    "calendarDays": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of calendar days from the reference event."
    },
    "businessDays": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of business days from the reference event."
    },
    "months": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of months from the reference event."
    },
    "penalty": {
      "type": "string",
      "description": "Consequence of missing the deadline."
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^cond-[a-z0-9-]+$" }
    },
    "notes": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "institution.schema.json#/$defs/sourceRef" }
    },
    "reviewStatus": {
      "$ref": "source.schema.json#/$defs/verificationStatus"
    },
    "reviewEvents": {
      "type": "array",
      "items": { "$ref": "review_event.schema.json" }
    }
  }
}
