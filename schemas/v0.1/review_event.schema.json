{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.org/schemas/v0.1/review_event.schema.json",
  "title": "ReviewEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "object_type",
    "reviewed_object_ids",
    "review_date",
    "review_type",
    "outcome",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^review:[a-z0-9-]+(:[a-z0-9-]+)*$"
    },
    "object_type": {
      "const": "ReviewEvent"
    },
    "reviewed_object_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "review_type": {
      "type": "string",
      "enum": [
        "maintainer",
        "source_check",
        "expert",
        "translation",
        "accessibility",
        "technical"
      ]
    },
    "reviewer_display": {
      "type": ["string", "null"],
      "description": "Public reviewer display name, if approved for publication."
    },
    "reviewer_private_ref": {
      "type": ["string", "null"],
      "description": "Optional internal reference. Do not include personal data unless appropriate."
    },
    "scope": {
      "type": ["string", "null"]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "rejected",
        "needs_expert_review",
        "stale",
        "superseded"
      ]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "created_by": {
          "type": "string"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "updated_by": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
